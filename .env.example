PORT=3000

CLERK_PUBLISHABLE_KEY=pk_test_your_publishable_key
CLERK_SECRET_KEY=sk_test_your_secret_key

# Copy this value from Clerk Dashboard > API keys > Quick Copy > JavaScript.
# Example:
# CLERK_FRONTEND_API_URL=verbena-lynx-00.clerk.accounts.dev
CLERK_FRONTEND_API_URL=

# Optional: override the Clerk browser script URL if needed.
# If left blank, the app derives it from CLERK_FRONTEND_API_URL.
CLERK_JS_URL=

# Optional role bootstrapping. Comma-separated email lists.
ADMIN_EMAILS=admin@sleekacademia.com
TUTOR_EMAILS=tutor@sleekacademia.com
